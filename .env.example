# ─── Database ─────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml). For production, your devops team
# supplies a real connection string pointing at the EC2 Postgres instance.
DATABASE_URL="postgresql://luckydraw:luckydraw@localhost:5433/luckydraw?schema=public"

# ─── better-auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ─── SMTP (NodeMailer) ────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# ─── File storage ─────────────────────────────────────────────────────
# "local" stores uploads under STORAGE_LOCAL_PATH. "s3" uses the S3_* vars.
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./storage"

# Optional — only required when STORAGE_DRIVER="s3"
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# ─── Tablet capture ───────────────────────────────────────────────────
# Auto-logs the tablet flow out to /login after this many minutes of
# inactivity. Fractional values are allowed (e.g. 0.5 = 30s for testing).
# Set to 0 to disable. Defaults to 15 when unset.
TABLET_IDLE_LOGOUT_MINUTES="15"

# ─── Bootstrap ────────────────────────────────────────────────────────
# Used once by `npm run seed:superadmin` to create the first SUPERADMIN.
# Remove or change after the initial user is created.
BOOTSTRAP_EMAIL=""
BOOTSTRAP_PASSWORD=""
